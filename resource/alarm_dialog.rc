/**
 * @file alarm_dialog.rc
 * @brief Alarm configuration dialog
 */
#include <windows.h>
#include "resource.h"

#pragma code_page(65001)

/** @brief Alarm time and message configuration dialog */
CLOCK_IDD_ALARM_DIALOG DIALOGEX 0, 0, 220, 160
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "Set Alarm"
FONT 9, "Segoe UI"
BEGIN
    GROUPBOX        "Alarm Time", IDC_ALARM_TIME_LABEL, 10, 10, 200, 50
    LTEXT           "Time (HH:MM):", CLOCK_IDC_STATIC, 20, 30, 60, 12
    EDITTEXT        IDC_ALARM_TIME_EDIT, 90, 28, 100, 14, ES_AUTOHSCROLL

    GROUPBOX        "Alarm Message", IDC_ALARM_MESSAGE_LABEL, 10, 65, 200, 45
    EDITTEXT        IDC_ALARM_MESSAGE_EDIT, 20, 82, 180, 20, ES_AUTOHSCROLL

    GROUPBOX        "Repeat", IDC_ALARM_DAYS_GROUP, 10, 115, 200, 30
    AUTOCHECKBOX    "One-time", IDC_ALARM_RECURRING_CHECK, 20, 127, 60, 12
    AUTOCHECKBOX    "Daily", IDC_ALARM_DAILY_CHECK, 90, 127, 50, 12

    PUSHBUTTON      "OK", IDOK, 160, 148, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 100, 148, 50, 14
END